<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base App Theme -->
    <style name="Theme.JntuhConnect" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Status Bar (top bar with time, battery, network, etc.) -->
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:windowBackground">@android:color/black</item>

        <!-- Light or dark icons in status bar (false = white icons) -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation Bar (bottom system buttons: home, back, recent) -->
        <item name="android:navigationBarColor">@android:color/black</item>
        <!-- Light or dark icons in nav bar (false = white icons) -->

        <item name="android:windowLightNavigationBar">false</item>
        <!-- or match MaterialTheme.colorScheme.background -->
        <item name="android:windowIsTranslucent">false</item>

        <!-- For Android 10+ (gesture nav), set divider color -->
        <item name="android:navigationBarDividerColor">@android:color/black</item>

        <!-- Optional: enforce full-screen edge-to-edge layout -->
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
    </style>

</resources>
